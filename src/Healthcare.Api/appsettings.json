{
  "ConnectionStrings": {
    "HealthcareDb": "Server=localhost;Database=healthcare;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "Healthcare.Api",
      "Audience": "Healthcare.Client",
      "SecretKey": "replace-with-a-long-random-secret-key-at-least-32-chars",
      "ExpiryMinutes": 60
    }
  },
  "Api": {
    "Version": "v1",
    "BasePath": "/api/v1"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
